# =============================================================================
# School Management System - Environment Variables Example
# =============================================================================
# This is a template file. Copy this to .env and fill in your actual values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# SECURITY: Never commit .env to version control. It contains secrets (passwords,
# API keys, etc.). The .env file is in .gitignore. Use this file as the template.
# =============================================================================

# =============================================================================
# Environment Configuration
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=6432
DB_NAME=user_service
DB_USERNAME=school_user
DB_PASSWORD=12345
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
FLYWAY_BASELINE_ON_MIGRATE=false

# =============================================================================
# Keycloak Authentication & Authorization
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=G1WsyHiIyo5ahZ
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# Keycloak Server URL - Choose based on your setup:
# - Local development (Docker): http://localhost:8070 (Docker port mapping 8070:8080)
# - Network/Remote access: http://YOUR_IP:8070 (e.g., http://100.72.220.128:8070)
# - Production with reverse proxy: https://auth-school-local.tech-visor.com
KEYCLOAK_SERVER_URL=http://100.72.220.128:8070
KEYCLOAK_REALM=school-management
# CONFIG with relative path
#KEYCLOAK_HOSTNAME=localhost:8070
#KEYCLOAK_RELATIVE_PATH=/auth

# Service account client for user-service admin operations
USER_PROFILE_CLIENT_ID=user-profile
USER_PROFILE_CLIENT_SECRET=ba27c36d-b238-4f4d-aae6-607a63cb1d98
# Keycloak integration bootstrap settings
KEYCLOAK_INITIALIZER_ENABLED=true
KEYCLOAK_INITIALIZER_MAX_ATTEMPTS=5
KEYCLOAK_INITIALIZER_BACKOFF=2000
KEYCLOAK_INITIALIZER_BACKOFF_MULTIPLIER=1.5
KEYCLOAK_INITIALIZER_FAIL_ON_ERROR=false
# Default Super Admin User
DEFAULT_ADMIN_EMAIL=admin@school.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_FIRSTNAME=Super
DEFAULT_ADMIN_LASTNAME=Administrator
DEFAULT_ADMIN_PHONE=+855123456789

# =============================================================================
# RabbitMQ Message Broker
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
# Outbox publisher
OUTBOX_PUBLISHER_MAX_ATTEMPTS=12
OUTBOX_PUBLISHER_INITIAL_BACKOFF_MS=1000
OUTBOX_PUBLISHER_MAX_BACKOFF_MS=60000
OUTBOX_PUBLISHER_POLL_INTERVAL_MS=2000

# Password reset
PASSWORD_RESET_PATH=/api/v1/auth/reset-password/confirm
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
PASSWORD_RESET_CLEANUP_CRON=0 30 3 * * *

# =============================================================================
# Elasticsearch Configuration
# =============================================================================
ELASTICSEARCH_CLUSTER_NAME=elasticsearch
ELASTICSEARCH_NODES=localhost:9300

# =============================================================================
# MinIO Object Storage
# =============================================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=900fe605-ddfe-4929-967c-6ed6ca734a0c

# =============================================================================
# Config Server Encryption
# =============================================================================
ENCRYPTION_KEYSTORE_PATH=classpath:keystore.jks
ENCRYPTION_KEYSTORE_PASSWORD=21d9b892-0f79-4536-b16a-be78971b4fe4
ENCRYPTION_KEY_ALIAS=config-server-key

CONFIG_SERVER_URL=http://localhost:8888
# Public API gateway base URL (https or http; optional port—omit 443 on https and 80 on http). No trailing slash. Drives user-service OpenAPI servers and email verification links.
API_GATEWAY_URL=http://localhost:8080
DISCOVERY_SERVER_URL=http://localhost:8761
EUREKA_INSTANCE_IP=127.0.0.1
